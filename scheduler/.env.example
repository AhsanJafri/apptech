FIREBASE_PROJECT_ID=your-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Cron: every 2 hours (default). Runs at 12am, 2am, 4am, 6am, 8am, etc.
CRON_SCHEDULE=0 */2 * * *

# Optional
TELEGRAM_BOT_TOKEN=
PORT=3000

# Set to "true" to run one check immediately on startup (useful for testing)
RUN_ON_STARTUP=false
